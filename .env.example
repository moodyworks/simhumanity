# Copy to .env and adjust. Never commit .env.
# All paths/secrets live here so moving to the Debian VPS is trivial.

# Where runtime data (event log DB, snapshots) lives.
# IMPORTANT on WSL2: keep this OFF the Windows drive (/mnt/...) — native Linux FS only.
SIMHUMANITY_DATA_DIR=/home/johnsterling/.local/share/simhumanity

# Server bind
SIMHUMANITY_HOST=127.0.0.1
SIMHUMANITY_PORT=8000

# Simulation pacing. Ticks per second the world advances at.
# Higher = faster gameplay; lower = a more deliberate pause between ticks.
SIMHUMANITY_TICK_HZ=3

# How many in-world minutes pass per tick (the time-dilation knob).
SIMHUMANITY_MINUTES_PER_TICK=30

# Ticks per era before the season clock advances to the next age.
# Pacing knob: set low (e.g. 5) for fast testing of the era transition.
SIMHUMANITY_TICKS_PER_ERA=600

# AI provider: auto (deepseek if key set, else stub) | deepseek | stub | ollama
SIMHUMANITY_AI_PROVIDER=auto

# AI layer (DeepSeek). Leave key blank to run with AI disabled (stub responses).
SIMHUMANITY_DEEPSEEK_API_KEY=
SIMHUMANITY_DEEPSEEK_MODEL=deepseek-chat
SIMHUMANITY_DEEPSEEK_BASE_URL=https://api.deepseek.com
